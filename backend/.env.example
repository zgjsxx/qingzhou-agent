# LLM Adapter Configuration
LLM_ADAPTER_TYPE=anthropic
LLM_API_KEY=sk-xxx
# For Anthropic Bearer authentication, set LLM_AUTH_TOKEN (or
# ANTHROPIC_AUTH_TOKEN directly) instead of LLM_API_KEY.
# LLM_AUTH_TOKEN=your-auth-token
LLM_BASE_URL=https://dashscope.aliyuncs.com/apps/anthropic
LLM_MODEL=glm-5.1
LLM_TEMPERATURE=0

# RAG configuration (optional)
RAG_EMBEDDING_PROVIDER=
RAG_EMBEDDING_MODEL=
RAG_EMBEDDING_API_KEY=
RAG_EMBEDDING_AUTH_TOKEN=
RAG_EMBEDDING_BASE_URL=
RAG_MINIMAX_GROUP_ID=
RAG_DOCS_DIR=
RAG_STORAGE_DIR=

# Shell tool configuration (optional)
SHELL_TOOL_MAX_OUTPUT_CHARS=12000

# Playwright browser tools (optional; restart backend after changing)
AGENT_PLAYWRIGHT_ENABLED=false
AGENT_PLAYWRIGHT_BROWSER=chromium
# Optional: use an installed Chrome/Edge instead of downloaded Chromium (chrome or msedge)
AGENT_PLAYWRIGHT_CHANNEL=
# On Windows, automatically use installed Edge/Chrome when channel is empty
AGENT_PLAYWRIGHT_AUTO_DETECT_CHANNEL=true
AGENT_PLAYWRIGHT_HEADLESS=true
AGENT_PLAYWRIGHT_TIMEOUT_MS=30000

# Context compaction configuration (optional)
AGENT_CONTEXT_COMPACT_ENABLED=true
AGENT_CONTEXT_MAX_MESSAGES=80
AGENT_CONTEXT_KEEP_HEAD_MESSAGES=4
AGENT_CONTEXT_KEEP_TAIL_MESSAGES=60
AGENT_CONTEXT_KEEP_RECENT_TOOL_RESULTS=4
AGENT_CONTEXT_TOOL_RESULT_MIN_CHARS=1200
AGENT_CONTEXT_TOOL_RESULT_BUDGET_CHARS=200000
AGENT_CONTEXT_PERSIST_THRESHOLD_CHARS=30000
AGENT_CONTEXT_PERSIST_PREVIEW_CHARS=2000
AGENT_CONTEXT_AUTO_SUMMARY_ENABLED=true
AGENT_CONTEXT_SUMMARY_TRIGGER_MESSAGES=140
AGENT_CONTEXT_SUMMARY_TRIGGER_CHARS=120000
AGENT_CONTEXT_SUMMARY_INPUT_CHARS=100000
AGENT_CONTEXT_POST_SUMMARY_KEEP_TAIL_MESSAGES=8
AGENT_CONTEXT_REACTIVE_KEEP_TAIL_MESSAGES=5
AGENT_SNIP_COMPACT_ENABLED=true
AGENT_SNIP_TRIGGER_MESSAGES=50
AGENT_SNIP_KEEP_HEAD_MESSAGES=3
AGENT_SNIP_KEEP_TAIL_MESSAGES=47

# Cron scheduler configuration (optional)
AGENT_CRON_ENABLED=false
AGENT_CRON_API_URL=http://localhost:2024
AGENT_CRON_ASSISTANT_ID=agent
AGENT_CRON_STORAGE_PATH=.agent_cron/scheduled_tasks.json
AGENT_CRON_POLL_SECONDS=30
AGENT_CRON_MAX_JOBS=50

# Feishu/Lark bot long-connection configuration (optional)
LARK_WS_ENABLED=false
LARK_APP_ID=cli_xxx
LARK_APP_SECRET=xxx

# Weixin iLink bot bridge (optional)
# First run: python scripts/weixin_login.py
WEIXIN_ENABLED=false
# Normally restored from backend/.weixin/account.json after QR login.
# WEIXIN_ACCOUNT_ID=
# WEIXIN_TOKEN=
# WEIXIN_BASE_URL=https://ilinkai.weixin.qq.com
WEIXIN_STREAM_ALL_MESSAGES=true
WEIXIN_HISTORY_MAX_MESSAGES=20
WEIXIN_REPLY_MAX_CHARS=2000

# Telegram Bot API bridge (optional)
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=123456789:replace-with-botfather-token
# Comma-separated numeric Telegram user IDs. Empty allows all users.
TELEGRAM_ALLOWED_USERS=
TELEGRAM_REQUIRE_MENTION=true
TELEGRAM_MERGE_WAIT_SECONDS=3
TELEGRAM_STREAM_ALL_MESSAGES=true
TELEGRAM_HISTORY_MAX_MESSAGES=20
TELEGRAM_REPLY_MAX_CHARS=4000

# Discord bot bridge (optional)
DISCORD_ENABLED=false
DISCORD_BOT_TOKEN=replace-with-discord-bot-token
# Comma-separated numeric Discord user IDs. Empty allows all users.
DISCORD_ALLOWED_USERS=
DISCORD_REQUIRE_MENTION=true
DISCORD_MERGE_WAIT_SECONDS=3
DISCORD_STREAM_ALL_MESSAGES=true
DISCORD_HISTORY_MAX_MESSAGES=20
DISCORD_REPLY_MAX_CHARS=1900
DISCORD_SEND_RETRIES=3
DISCORD_CONNECT_RETRY_SECONDS=15
# Optional, for networks where Discord REST requests are unstable.
# DISCORD_PROXY=http://127.0.0.1:7890
LARK_HISTORY_MAX_MESSAGES=20
LARK_REPLY_MAX_CHARS=12000
LARK_DEBUG=false

# Tencent QQ bot configuration via qq-botpy (optional)
BOTPY_ENABLED=false
BOTPY_APPID=
BOTPY_SECRET=
BOTPY_SANDBOX=false
BOTPY_HISTORY_MAX_MESSAGES=20
BOTPY_REPLY_MAX_CHARS=1500
BOTPY_PUBLIC_GUILD_MESSAGES=true
BOTPY_DIRECT_MESSAGE=true
BOTPY_PUBLIC_MESSAGES=false

# Model recovery configuration (optional)
AGENT_RECOVERY_ENABLED=true
AGENT_RECOVERY_MAX_RETRIES=5
AGENT_RECOVERY_BASE_DELAY_MS=500
AGENT_RECOVERY_MAX_DELAY_MS=32000
AGENT_RECOVERY_JITTER_RATIO=0.25
AGENT_RECOVERY_MAX_CONSECUTIVE_529=3
AGENT_RECOVERY_ESCALATE_MAX_TOKENS=true
AGENT_RECOVERY_ESCALATED_MAX_TOKENS=64000
AGENT_RECOVERY_MAX_TOKENS_PARAM=max_tokens
# LLM_FALLBACK_ADAPTER_TYPE=openai
# LLM_FALLBACK_MODEL=gpt-4.1-mini
# LLM_FALLBACK_API_KEY=sk-xxx
# LLM_FALLBACK_BASE_URL=https://api.openai.com/v1

# Subagent configuration (optional)
AGENT_SUBAGENT_MAX_STEPS=30
AGENT_SUBAGENT_MAX_STEPS_LIMIT=60

# Memory configuration (optional)
AGENT_MEMORY_ENABLED=true
AGENT_MEMORY_MAX_RELEVANT=5
AGENT_MEMORY_INDEX_MAX_LINES=200
AGENT_MEMORY_INDEX_MAX_CHARS=25000
AGENT_MEMORY_FILE_MAX_CHARS=4096
AGENT_MEMORY_TOTAL_MAX_CHARS=60000

# Permission configuration (optional)
AGENT_PERMISSION_ALLOW_ASK_RULES=false

# Agent logging configuration (optional)
AGENT_LOG_ENABLED=false
AGENT_LOG_DIR=./logs
AGENT_LOG_MAX_BYTES=10485760
AGENT_LOG_BACKUP_COUNT=5

# LangSmith tracing (optional)
# LANGSMITH_API_KEY=lsv2_xxx
# LANGSMITH_TRACING=true
# LANGSMITH_PROJECT=xu-agent

# Frontend URL for download links (optional, default http://localhost:3000)
FRONTEND_URL=http://localhost:3000
