# LLM Adapter Configuration
LLM_ADAPTER_TYPE=anthropic
LLM_API_KEY=sk-xxx
LLM_BASE_URL=https://dashscope.aliyuncs.com/apps/anthropic
LLM_MODEL=glm-5.1
LLM_TEMPERATURE=0

# Shell tool configuration (optional)
SHELL_TOOL_MAX_OUTPUT_CHARS=12000

# Context compaction configuration (optional)
AGENT_CONTEXT_COMPACT_ENABLED=true
AGENT_CONTEXT_MAX_MESSAGES=80
AGENT_CONTEXT_KEEP_HEAD_MESSAGES=4
AGENT_CONTEXT_KEEP_TAIL_MESSAGES=60
AGENT_CONTEXT_KEEP_RECENT_TOOL_RESULTS=4
AGENT_CONTEXT_TOOL_RESULT_MIN_CHARS=1200
AGENT_CONTEXT_TOOL_RESULT_BUDGET_CHARS=200000
AGENT_CONTEXT_PERSIST_THRESHOLD_CHARS=30000
AGENT_CONTEXT_PERSIST_PREVIEW_CHARS=2000
AGENT_CONTEXT_AUTO_SUMMARY_ENABLED=true
AGENT_CONTEXT_SUMMARY_TRIGGER_MESSAGES=140
AGENT_CONTEXT_SUMMARY_TRIGGER_CHARS=120000
AGENT_CONTEXT_SUMMARY_INPUT_CHARS=100000
AGENT_CONTEXT_POST_SUMMARY_KEEP_TAIL_MESSAGES=8
AGENT_CONTEXT_REACTIVE_KEEP_TAIL_MESSAGES=5

# Subagent configuration (optional)
AGENT_SUBAGENT_MAX_STEPS=30
AGENT_SUBAGENT_MAX_STEPS_LIMIT=60

# Memory configuration (optional)
AGENT_MEMORY_ENABLED=true
AGENT_MEMORY_MAX_RELEVANT=5
AGENT_MEMORY_INDEX_MAX_LINES=200
AGENT_MEMORY_INDEX_MAX_CHARS=25000
AGENT_MEMORY_FILE_MAX_CHARS=4096
AGENT_MEMORY_TOTAL_MAX_CHARS=60000

# Permission configuration (optional)
AGENT_PERMISSION_ALLOW_ASK_RULES=false

# Agent logging configuration (optional)
AGENT_LOG_ENABLED=false
AGENT_LOG_DIR=./logs
AGENT_LOG_MAX_BYTES=10485760
AGENT_LOG_BACKUP_COUNT=5

# LangSmith tracing (optional)
# LANGSMITH_API_KEY=lsv2_xxx
# LANGSMITH_TRACING=true
# LANGSMITH_PROJECT=xu-agent
