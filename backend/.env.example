# LLM Adapter Configuration
LLM_ADAPTER_TYPE=anthropic
LLM_API_KEY=sk-xxx
LLM_BASE_URL=https://dashscope.aliyuncs.com/apps/anthropic
LLM_MODEL=glm-5.1
LLM_TEMPERATURE=0

# Shell tool configuration (optional)
SHELL_TOOL_MAX_OUTPUT_CHARS=12000

# Agent logging configuration (optional)
AGENT_LOG_DIR=./logs
AGENT_LOG_MAX_BYTES=10485760
AGENT_LOG_BACKUP_COUNT=5

# LangSmith tracing (optional)
# LANGSMITH_API_KEY=lsv2_xxx
# LANGSMITH_TRACING=true
# LANGSMITH_PROJECT=xu-agent
